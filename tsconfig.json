{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["ES2022", "DOM"],
    "types": ["bun-types"]
  },
  "include": ["packages/*/src/**/*"],
  "exclude": ["**/dist/**", "**/node_modules/**", "**/*.test.ts", "scripts/**"]
}
