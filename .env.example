# required — twitch bot credentials
TWITCH_CHANNELS=your_channel
TWITCH_USERNAME=your_bot_username
TWITCH_TOKEN=oauth:your_token_here
TWITCH_REFRESH_TOKEN=your_refresh_token_here
TWITCH_CLIENT_ID=your_client_id
TWITCH_CLIENT_SECRET=your_client_secret

# required for AI features (!b <question>, copypasta, style, etc)
ANTHROPIC_API_KEY=sk-ant-...

# bot admin
BOT_OWNER=your_twitch_username
ALIAS_ADMINS=comma,separated,usernames

# optional — defaults to TWITCH_CHANNELS if not set
AI_CHANNELS=channel1,channel2

# optional — users who bypass AI cooldowns
AI_VIP=user1,user2

# --- EBS (extension backend) only ---
# TWITCH_EXTENSION_CLIENT_ID=your_extension_client_id
# TWITCH_EXTENSION_SECRET=your_extension_secret
# COMPANION_SECRET=shared_secret_for_companion
# EBS_PORT=3100
# CACHE_PATH=cache/items.json
