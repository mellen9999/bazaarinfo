{
  "name": "@bazaarinfo/extension",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build:overlay && bun run build:panel",
    "build:overlay": "esbuild src/overlay.tsx --bundle --outfile=dist/video_overlay.js --format=iife --platform=browser --loader:.css=css --jsx=automatic --jsx-import-source=preact",
    "build:panel": "esbuild src/panel.tsx --bundle --outfile=dist/panel.js --format=iife --platform=browser --loader:.css=css --jsx=automatic --jsx-import-source=preact"
  },
  "dependencies": {
    "@bazaarinfo/shared": "workspace:*",
    "preact": "^10.19.0"
  },
  "devDependencies": {
    "esbuild": "^0.20.0"
  }
}
