  "viewer_urls": {
    "video_overlay": "video_overlay.html",
    "panel": "panel.html"
  },
  "config_url": "config.html",
  "live_config_url": "config.html",
  "asset_urls": {
    "icon_24": "assets/icon_24.png",
    "icon_300": "assets/icon_300.png",
    "icon_1080": "assets/icon_1080.png",
    "screenshot_1": "assets/screenshot_overlay.png",
    "screenshot_2": "assets/screenshot_panel.png",
    "screenshot_3": "assets/screenshot_setup.png"
  },
  "required_permissions": ["broadcast"],
  "whitelisted_config_urls": [],
  "whitelisted_panel_urls": [],
  "ebs_url": "https://ebs.bazaarinfo.com",
